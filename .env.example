# =============================================
# AI-Edu-OpenCode - 环境变量模板
# 复制到 .env.local 并填入实际值
# =============================================

# Node
NODE_ENV=development

# =============================================
# Database (Neon Postgres)
# =============================================
# 从 https://console.neon.tech/ 获取
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# =============================================
# Auth.js v5
# =============================================
# 生成: openssl rand -base64 32
AUTH_SECRET=replace-with-32-char-random-string
AUTH_URL=http://localhost:3000
# Trust the host header in dev(ngrok, etc.)
AUTH_TRUST_HOST=true

# OAuth providers(可选)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# =============================================
# AI - DeepSeek
# =============================================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 备用(Anthropic Claude)
ANTHROPIC_API_KEY=

# Embedding 服务(bge-m3 / Qwen3-Embedding)
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024

# =============================================
# Storage - Cloudflare R2
# =============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ai-learning-artifacts
R2_PUBLIC_URL=

# =============================================
# Observability
# =============================================
# Langfuse (https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Sentry
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# =============================================
# App
# =============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
