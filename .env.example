# =============================================
# AI-Edu-OpenCode - v1 production env template
# Copy to .env.local for dev / .env.production for deploy
# v1 minimal stack: Vercel + Neon + DeepSeek + Langfuse + PostHog
# =============================================

# Node
NODE_ENV=development

# =============================================
# Database - Neon Postgres (pooled connection)
# =============================================
# From https://console.neon.tech → Connection Details
# Switch to "Pooled connection" tab, click "Show password"
# Format: postgresql://USER:PWD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# =============================================
# Auth.js v5
# =============================================
# Generate: [Convert]::ToBase64String((1..32|%{Get-Random -Max 256})) (PowerShell)
# Or: openssl rand -base64 32
AUTH_SECRET=replace-with-32-byte-base64-string
# Production URL (Vercel assigns this after first deploy)
AUTH_URL=http://localhost:3000
# Required for Vercel (host header trust)
AUTH_TRUST_HOST=true

# OAuth providers (optional, add later)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# =============================================
# AI - DeepSeek (only LLM in v1)
# =============================================
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# =============================================
# Observability - Langfuse (LLM traces)
# =============================================
# From https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================
# Observability - PostHog (product analytics)
# =============================================
# From https://us.i.posthog.com → Settings → Project
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# =============================================
# App
# =============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
